{
  "name": "@core/posthog",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "check-types": "tsc --build --emitDeclarationOnly",
    "lint": "oxlint -c ../../tooling/oxc/oxlintrc.core.json",
    "format": "oxfmt --write src"
  },
  "dependencies": {
    "@core/env": "workspace:*",
    "posthog-js": "^1.236.0",
    "posthog-node": "^4.7.1"
  },
  "devDependencies": {
    "@tooling/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "^5"
  }
}
